# Environment variables (copy to `.env` — never commit real secrets)

# Optional: canonical URL for SEO Open Graph & canonical tags (no trailing slash)
# Example: https://your-project-id.web.app
# VITE_SITE_URL=

# Firebase (required — from Firebase console)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# ...

# Optional: EmailJS for appointment email notifications (account booking flow)
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
# VITE_EMAILJS_PUBLIC_KEY=
