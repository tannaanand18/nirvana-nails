# Copy to `.env` locally — never commit real secrets

# Firebase (required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin access: comma-separated emails get admin role on sign-in (no password)
# Example: your@gmail.com,owner@nirvananails.com
VITE_ADMIN_EMAILS=

# Optional SEO
# VITE_SITE_URL=https://your-site.vercel.app
